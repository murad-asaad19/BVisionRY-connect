# Dependencies
node_modules/

# Environment
.env
.env.local
.env*.local
.playwright-mcp
# Supabase local state
supabase/.temp/
supabase/.branches/

# Expo local cache
.expo/

# Claude scheduled-task state
.claude/scheduled_tasks.lock

# Audit artefacts (the audit doc itself is kept; the raw screenshots are large)
.audit-screenshots/

# Ad-hoc screenshots from debugging / smoke checks stay out of the repo…
*.png
# …but the Flutter app's shipped artwork IS source-controlled (launcher icons,
# adaptive/splash assets, iOS asset catalog, web PWA icons, and the brand
# source art used to regenerate them). Without these, a clean checkout / CI /
# release build ships with no app icon.
!mobile_flutter/assets/**/*.png
!mobile_flutter/android/app/src/main/res/**/*.png
!mobile_flutter/ios/Runner/Assets.xcassets/**/*.png
!mobile_flutter/web/**/*.png
# Allow Flutter golden snapshots — they ARE source-controlled artifacts.
!mobile_flutter/**/goldens/**/*.png

# IDE
.idea/
.vscode/

# Internal docs (not for upstream)
docs/*
# Phase 15 — top-level flutter-rebuild doc IS shipped.
!docs/flutter-readme.md

# Claude / MCP local config
.claude/settings.local.json
.mcp.json

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# OS
.DS_Store
Thumbs.db

# Build artifacts
dist/
build/
coverage/

# Flutter rebuild
mobile_flutter/.dart_tool/
mobile_flutter/build/
mobile_flutter/.flutter-plugins
mobile_flutter/.flutter-plugins-dependencies
mobile_flutter/ios/Pods/
mobile_flutter/ios/.symlinks/
mobile_flutter/ios/Flutter/Flutter.framework/
mobile_flutter/ios/Flutter/Flutter.podspec
mobile_flutter/env/*.json
!mobile_flutter/env/*.json.example
# Phase 15 — release secrets (real configs, keystore, entitlements overrides)
mobile_flutter/android/key.properties
mobile_flutter/android/keystore/
mobile_flutter/android/app/google-services.json
mobile_flutter/ios/Runner/GoogleService-Info.plist
mobile_flutter/ios/Runner/Runner.entitlements.local
mobile_flutter/sentry.properties

