# =============================================================================
# Mobile app environment variables — template. Copy to `.env.local` for local
# dev (gitignored), and set the same keys via EAS for preview/production
# builds.
#
# SECURITY WARNING: every `EXPO_PUBLIC_*` variable is INLINED into the
# JavaScript bundle at build time. They are therefore PUBLIC — anyone who
# downloads the app can read them. NEVER put service-role keys, signing
# secrets, OpenAI keys, or any other server-side secret in an
# `EXPO_PUBLIC_*` variable. The Supabase anon key is safe here (it is
# rate-limited and bounded by RLS); the service-role key is NOT.
#
# How to set values:
#   - Local dev:        `mobile/.env.local` (gitignored)
#   - EAS preview/prod: `eas secret:create --scope project --name <KEY> --value '<VALUE>'`
#                       (or via the EAS dashboard). Then reference in eas.json
#                       — see the per-profile `env` blocks. The literal string
#                       `SET_IN_EAS_SECRETS` in eas.json is a sentinel meaning
#                       "must be overridden by an EAS secret of the same name".
#   - CI:               same as EAS, via repo secrets surfaced as env vars.
#
# Build-time-only secrets (NOT bundled, NOT `EXPO_PUBLIC_*`):
#   SENTRY_AUTH_TOKEN, SENTRY_ORG, SENTRY_PROJECT — used by the @sentry/react-native
#   Expo plugin to upload source maps during `eas build`. Set as EAS secrets;
#   do NOT add `EXPO_PUBLIC_` prefix.
# =============================================================================

# ---------------------------------------------------------------------------
# REQUIRED — app will throw on boot (see src/lib/env.ts) if missing.
# ---------------------------------------------------------------------------

# Supabase project URL. Local dev: http://127.0.0.1:54321
# Preview/production: https://<project-ref>.supabase.co
EXPO_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321

# Supabase publishable / anon key. Safe to ship in client bundle (RLS bounds
# what it can read/write). Get from Supabase Dashboard > Settings > API.
EXPO_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_replace_me

# ---------------------------------------------------------------------------
# OPTIONAL — sensible defaults are applied if missing.
# ---------------------------------------------------------------------------

# Sentry DSN for crash + error reporting. Leave blank to disable Sentry init.
# Get from Sentry > Settings > Projects > <project> > Client Keys (DSN).
EXPO_PUBLIC_SENTRY_DSN=

# Sentry environment tag — surfaces in Sentry UI as the `environment` filter.
# Common values: dev, preview, production. Defaults to "dev".
EXPO_PUBLIC_SENTRY_ENV=dev

# Toggles @react-native-firebase initialization (Crashlytics, FCM). Accepts
# "true" / "TRUE" / "1" (case-insensitive). Anything else → disabled.
# Keep `false` in dev (no Firebase config) and `true` for preview/production
# builds with real Firebase config files in place.
EXPO_PUBLIC_FIREBASE_ENABLED=false

# ---------------------------------------------------------------------------
# BUILD-TIME (read by app.config.ts, not by runtime env.ts).
# These must be set at the time `expo prebuild` / `eas build` runs.
# ---------------------------------------------------------------------------

# EAS project id (UUID). Set after running `eas init` once per project. Used
# to build the EAS Update URL (https://u.expo.dev/<id>) and `extra.eas.projectId`.
# Falls back to literal "PROJECT_ID_PLACEHOLDER" if unset, which will break
# OTA updates — set it for any build you intend to publish.
EXPO_PUBLIC_EAS_PROJECT_ID=

# Universal/App Links host (no scheme, no path). Used to register
# `applinks:<host>` (iOS associatedDomains) and the Android intent filter
# for `https://<host>/p/<handle>` so profile links open the app directly.
# Example: connect.bvisionry.com  (the app also accepts www.<host>).
# Falls back to literal "DOMAIN_PLACEHOLDER" if unset, which will produce a
# broken build for App/Universal Links.
EXPO_PUBLIC_APP_LINKS_HOST=
