<?xml version="1.0" encoding="UTF-8"?>
<!-- EXAMPLE / TEMPLATE FILE.
     Copy this file to `GoogleService-Info.plist` (drop the `.example`
     suffix) and replace the placeholder values with the real ones from
     the Firebase Console:
       Firebase Console > Project Settings > General > Your apps > iOS app
       > GoogleService-Info.plist (download).
     The real file is gitignored. Do NOT commit real Firebase credentials.
     For EAS builds, upload the real file via `eas credentials` or place
     it in the build environment; never check it into source control. -->
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>API_KEY</key><string>placeholder-api-key</string>
  <key>BUNDLE_ID</key><string>com.bvisionry.connect</string>
  <key>GOOGLE_APP_ID</key><string>1:000000000000:ios:placeholder</string>
  <key>PROJECT_ID</key><string>placeholder-bvisionry</string>
  <key>GCM_SENDER_ID</key><string>000000000000</string>
  <key>STORAGE_BUCKET</key><string>placeholder-bvisionry.appspot.com</string>
  <key>IS_ADS_ENABLED</key><false/>
  <key>IS_ANALYTICS_ENABLED</key><false/>
  <key>IS_APPINVITE_ENABLED</key><true/>
  <key>IS_GCM_ENABLED</key><true/>
  <key>IS_SIGNIN_ENABLED</key><true/>
  <key>PLIST_VERSION</key><string>1</string>
</dict>
</plist>
