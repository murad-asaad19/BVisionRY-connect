# =============================================================================
# Supabase Edge Functions environment — template. Copy to `supabase/.env`
# (gitignored) for local `supabase functions serve`. For deployed projects,
# push values with:
#
#   supabase secrets set --env-file supabase/.env
#
# (or set individual secrets with `supabase secrets set KEY=value`).
#
# Most variables prefixed `SUPABASE_*` are auto-injected by the Supabase
# Edge runtime in production — you only need them locally. Custom secrets
# (WEBHOOK_SHARED_SECRET, FCM_SERVICE_ACCOUNT_JSON, WHISPER/OpenAI keys,
# MAILER_KEY) MUST be set explicitly with `supabase secrets set`.
#
# See `supabase/functions/README.md` for which env var each function
# consumes, the Postgres GUCs required for the dispatchers, and rotation
# procedure.
# =============================================================================

# ---------------------------------------------------------------------------
# Auto-injected in Supabase Cloud — REQUIRED locally for `functions serve`.
# Pull from `supabase status` after running `supabase start`.
# ---------------------------------------------------------------------------

# Local default: http://127.0.0.1:54321
# Production:    https://<project-ref>.supabase.co
SUPABASE_URL=http://127.0.0.1:54321

# Public anon / publishable key. Used by auth-handle-login and delete-account
# to scope JWT verification on incoming requests. Safe to expose to clients.
SUPABASE_ANON_KEY=sb_publishable_replace_me

# SERVICE-ROLE key — bypasses RLS. NEVER ship in a client; only set on the
# server (edge function runtime). Treat as a root credential.
SUPABASE_SERVICE_ROLE_KEY=sb_secret_replace_me

# ---------------------------------------------------------------------------
# Shared secret used by webhook-style functions (send-push, transcribe-voice).
# MUST match the Postgres GUC `app.webhook_shared_secret` exactly — the
# dispatcher SQL functions pass this in the X-Supabase-Webhook-Secret header.
# Generate a fresh 32+ char random string and rotate periodically.
# Example:  openssl rand -hex 32
# ---------------------------------------------------------------------------
WEBHOOK_SHARED_SECRET=replace_with_32_char_random_string

# ---------------------------------------------------------------------------
# Firebase Cloud Messaging (FCM v1) — required for `send-push` in
# preview/production. Optional in local dev (the function logs and no-ops
# when missing).
#
# Value: the FULL Google service account JSON, single-line (escape newlines
# in the private_key) OR base64-encoded. See send-push/index.ts for the
# accepted shapes.
#
# Generate: Firebase Console > Project Settings > Service accounts >
# Generate new private key (downloads a .json).
# ---------------------------------------------------------------------------
FCM_SERVICE_ACCOUNT_JSON=

# ---------------------------------------------------------------------------
# Whisper / OpenAI transcription — required for `transcribe-voice` in
# preview/production. The function prefers WHISPER_API_KEY; if absent it
# falls back to OPENAI_API_KEY. Optional in local dev (the function logs and
# no-ops when missing).
# ---------------------------------------------------------------------------
WHISPER_API_KEY=
OPENAI_API_KEY=

# ---------------------------------------------------------------------------
# Anthropic API key — used by `infer-goal-type` (and future Claude-backed
# functions like `meeting-playbook`). Required in preview/prod; if missing,
# the function responds 500 `{error: "server_misconfigured"}` so clients
# fail loud rather than silently dropping inferences.
# ---------------------------------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-

# ---------------------------------------------------------------------------
# Outbound email — used by `goal-staleness-reminder` when sending nudge
# emails. Optional in dev (the function logs and skips sending if missing).
# Substitute with the credential format expected by your mailer (SendGrid /
# Postmark / Resend API key, etc.).
# ---------------------------------------------------------------------------
MAILER_KEY=

# =============================================================================
# Postgres GUCs (NOT env vars) — these are session/cluster settings the
# database dispatcher functions read via `current_setting('app.<name>', true)`.
# They are NOT injected by `supabase secrets set`. Set them once per database
# with `alter database`:
#
#   alter database postgres
#     set app.functions_base_url = 'https://<project-ref>.functions.supabase.co';
#   alter database postgres
#     set app.webhook_shared_secret = '<same-value-as-WEBHOOK_SHARED_SECRET>';
#
# Local dev: run the same statements against your local cluster, e.g. via
# `psql "$DATABASE_URL"` or the Supabase Studio SQL editor. For local edge
# functions served by `supabase functions serve`, point app.functions_base_url
# at http://host.docker.internal:54321/functions/v1 (or 127.0.0.1 when not
# running inside Docker).
#
# Rotation: update GUC and WEBHOOK_SHARED_SECRET together. Any drift
# between them produces 401s from send-push / transcribe-voice on every
# dispatch.
# =============================================================================
